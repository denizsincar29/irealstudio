msgstr "{section} в такте {m}"

# --- bass note ---
msgid "Invalid note"
msgstr "Неверная нота"

msgid "No chord to modify"
msgstr "Нет аккорда для изменения"

# --- volta brackets ---
msgid "Repeat from measure {repeat_start}, ending 1: {e1_start}–{e1_end}, ending 2 starts at measure {e2_start}"
msgstr "Повтор с такта {repeat_start}, окончание 1: {e1_start}–{e1_end}, окончание 2 начинается с такта {e2_start}"

msgid " ({n} hidden chord removed)"
msgid_plural " ({n} hidden chords removed)"
msgstr[0] " (удалён {n} скрытый аккорд)"
msgstr[1] " (удалено {n} скрытых аккорда)"
msgstr[2] " (удалено {n} скрытых аккордов)"

# --- playback / recording ---
msgid "Stopped"
msgstr "Остановлено"

msgid "Beat offset {offset:.0f} milliseconds"
msgstr "Смещение по доле: {offset:.0f} мс"

# --- file operations ---
