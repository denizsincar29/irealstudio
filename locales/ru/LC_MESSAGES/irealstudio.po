# --- keyboard shortcuts dialog ---
msgid "Keyboard Shortcuts – IReal Studio"
msgstr "Горячие клавиши – IReal Studio"

#, fuzzy
msgid ""
"Keyboard Shortcuts – IReal Studio\n"
"==================================\n"
"\n"
"Navigation\n"
"  Left / Right          Move cursor one chord\n"
"  Alt+Left / Alt+Right  Move cursor one beat\n"
"  Ctrl+Left / Ctrl+Right  Move cursor one measure\n"
"  Ctrl+Home / Ctrl+End  Go to beginning / end\n"
"  Shift+Left / Right    Extend selection\n"
"\n"
"Playback & Recording\n"
"  R                     Start / stop recording\n"
"  Space                 Play / stop\n"
"  Ctrl+Space            Stop and jump to last position\n"
"  Escape                Stop recording or playback\n"
"\n"
"Editing\n"
"  Delete / Backspace          Delete chord at cursor\n"
"  Ctrl+Delete / Ctrl+Backspace  Delete structural mark at cursor\n"
"                               (section mark, repeat bracket, N.C.)\n"
"  Ctrl+Z / Ctrl+Y       Undo / Redo\n"
"  Ctrl+X / Ctrl+C / Ctrl+V  Cut / Copy / Paste chord\n"
"  Ctrl+Return           Insert chord (dialog)\n"
"  N                     Toggle No Chord (N.C.)\n"
"\n"
"Section Marks (Ctrl+Shift+letter)\n"
"  Ctrl+Shift+A/B/C/D    Section A / B / C / D\n"
"  Ctrl+Shift+V          Verse\n"
"  Ctrl+Shift+I          Intro\n"
"\n"
"Other\n"
"  V                     Add volta / ending bracket\n"
"  / + (A–G)             Add bass note (slash chord)\n"
"  P                     Speak full position\n"
"  D                     Beat offset (debug)\n"
"  Ctrl+N                New project\n"
"  Ctrl+O                Open file\n"
"  Ctrl+S                Save\n"
"  Ctrl+E                Export to iReal Pro\n"
"  Ctrl+Shift+E          Show QR code\n"
"  Ctrl+L                Speak recent log entries\n"
"  F1                    Keyboard shortcuts\n"
"  Ctrl+Q                Quit\n"
msgstr ""
"Горячие клавиши – IReal Studio\n"
"================================\n"
"\n"
"Навигация\n"
"  Left / Right              Перемещение на один аккорд\n"
"  Alt+Left / Alt+Right      Перемещение на одну долю\n"
"  Ctrl+Left / Ctrl+Right    Перемещение на один такт\n"
"  Ctrl+Home / Ctrl+End      В начало / в конец\n"
"  Shift+Left / Right        Расширить выделение\n"
"\n"
"Воспроизведение и запись\n"
"  R                         Начать / остановить запись\n"
"  Space                     Воспроизвести / остановить\n"
"  Ctrl+Space                Остановить и перейти к точке остановки\n"
"  Escape                    Остановить запись или воспроизведение\n"
"\n"
"Редактирование\n"
"  Delete / Backspace              Удалить аккорд под курсором\n"
"  Ctrl+Delete / Ctrl+Backspace    Удалить структурную метку (раздел, повтор, N.C.)\n"
"  Ctrl+Z / Ctrl+Y           Отменить / Повторить\n"
"  Ctrl+X / Ctrl+C / Ctrl+V  Вырезать / Скопировать / Вставить аккорд\n"
"  Ctrl+Return               Вставить аккорд (диалог)\n"
"  N                         Вставить или удалить знак N.C. (нет аккорда)\n"
"\n"
"Метки частей (Ctrl+Shift+буква)\n"
"  Ctrl+Shift+A/B/C/D        Часть A / B / C / D\n"
"  Ctrl+Shift+V              Куплет\n"
"  Ctrl+Shift+I              Вступление\n"
"\n"
"Прочее\n"
"  V                         Добавить вольту / окончание\n"
"  / + (A–G)                 Добавить бас-ноту (слэш-аккорд)\n"
"  P                         Озвучить полную позицию\n"
"  D                         Смещение по доле (отладка)\n"
"  Ctrl+N                    Новый проект\n"
"  Ctrl+O                    Открыть файл\n"
"  Ctrl+S                    Сохранить\n"
"  Ctrl+E                    Экспорт в iReal Pro\n"
"  Ctrl+Shift+E              Показать QR-код\n"
"  Ctrl+L                    Прочитать последние записи журнала\n"
"  F1                        Горячие клавиши\n"
"  Ctrl+Q                    Выход\n"

msgid "Keyboard shortcuts dialog opened. Press OK to close."
msgstr "Диалог горячих клавиш. Нажмите OK для закрытия."

