# --- startup / status ---
msgid "QR code export requires the qrcode package (uv add qrcode)"
msgstr "Для экспорта QR-кода требуется пакет qrcode (uv add qrcode)"

msgid "QR code generation failed: {e}"
msgstr "Ошибка генерации QR-кода: {e}"

msgid "QR code ready but no window to display it"
msgstr "QR-код готов, но нет окна для отображения"

# --- keyboard shortcuts dialog ---
msgid "Keyboard Shortcuts – IReal Studio"
msgstr "Горячие клавиши – IReal Studio"

msgid "Keyboard shortcuts dialog opened. Press OK to close."
msgstr "Диалог горячих клавиш открыт. Нажмите OK для закрытия."

# --- about dialog ---
msgid "A blind-accessible chord progression recorder\nfor musicians who use screen readers.\n\nExport chord charts to iReal Pro format."
msgstr "Редактор аккордовых прогрессий с поддержкой экранного чтения\nдля незрячих музыкантов.\n\nЭкспорт в формат iReal Pro."

msgid "(C) 2024 Deniz Sincar"
msgstr "© 2024 Денис Синчар"

# --- editing ---
msgid "Deleted"
msgstr "Удалено"

msgid "section mark"
msgstr "метка раздела"

msgid "repeat bracket"
msgstr "знак повтора"

msgid "N.C."
msgstr "N.C."

msgid "Deleted {items} at measure {m}"
msgstr "Удалено: {items} в такте {m}"

msgid "Nothing to delete at measure {m} beat {b}"
msgstr "Нечего удалять в такте {m} доле {b}"

# --- section marks ---
msgid "Section A"
msgstr "Раздел A"

msgid "Section B"
msgstr "Раздел B"

msgid "Section C"
msgstr "Раздел C"

msgid "Section D"
msgstr "Раздел D"

msgid "Verse"
msgstr "Куплет"

